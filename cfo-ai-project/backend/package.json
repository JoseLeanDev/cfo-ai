{
  "name": "cfo-ai-backend",
  "version": "1.0.0",
  "description": "CFO AI Backend API with Multi-Agent System",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "node database/migrate.js",
    "migrate:postgres": "node database/migrate-postgres.js",
    "seed": "node database/seed.js",
    "scheduler": "node src/scheduler/run.js",
    "scheduler:setup": "node src/scheduler/setup.js",
    "agents": "node agents/index.js",
    "agents:start": "node agents/index.js",
    "build": "npm run migrate && npm run seed && npm run build:frontend",
    "build:frontend": "cd ../frontend && npm install --include=dev && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}

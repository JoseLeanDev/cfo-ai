# CFO AI Environment Configuration
# Copia este archivo a .env y configura tus variables

# Database
DATABASE_URL=./database/cfo_ai.db

# LLM Provider - OpenRouter (Recomendado)
# Obtén tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-api-key-aqui
LLM_PROVIDER=openrouter

# App URL (for OpenRouter referer)
APP_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development

# Opcional: Kimi API Key (alternativa)
# KIMI_API_KEY=your-kimi-key-here
